		"@payloadcms/richtext-lexical": "3.80.0",
		"@payloadcms/storage-s3": "3.80.0",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-slot": "^1.0.2",
		"@radix-ui/react-switch": "^1.0.3",
		"@vercel/analytics": "^1.5.0",
